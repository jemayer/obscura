{
  "name": "obscura",
  "version": "0.1.0",
  "description": "A purpose-built static site generator for photography portfolio websites.",
  "type": "module",
  "main": "dist-build/index.js",
  "scripts": {
    "build": "tsc && node dist-build/cli.js",
    "build:clean": "tsc && node dist-build/cli.js --clean",
    "dev": "tsc && node dist-build/dev.js",
    "dev:clean": "tsc && node dist-build/dev.js --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "compile": "tsc",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "validate": "tsc && node dist-build/validate.js",
    "sidecar": "tsc && node dist-build/sidecar-cli.js",
    "init": "tsc && node dist-build/init.js",
    "migrate": "tsc && node dist-build/migrate.js"
  },
  "keywords": [
    "static-site-generator",
    "photography",
    "portfolio"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "@types/nunjucks": "^3.2.6",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "chokidar": "^3.6.0",
    "exifr": "^7.1.3",
    "nunjucks": "^3.2.4",
    "photoswipe": "^5.4.4",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "unified": "^11.0.5",
    "yaml": "^2.8.2"
  }
}
