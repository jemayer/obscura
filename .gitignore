# Claude
.claude/
.beans/
.beans.yml

# ============================================================
# Build artifacts — always regenerated, never committed
# ============================================================
node_modules/
dist/
dist-build/
.cache/

# ============================================================
# Large photo binaries (see ADR-011)
#
# Everything under site/ is yours and safe to commit — config,
# sidecars, posts, pages, custom themes. The only exception is
# original photo files, which are too large for git.
#
# This matters if you deploy via CI (GitHub Pages, Netlify, etc.)
# and need your content in the repository. If you only build
# locally, you don't need to commit any of site/ at all.
# ============================================================
site/content/photos/**/*.jpg
site/content/photos/**/*.jpeg
site/content/photos/**/*.png
site/content/photos/**/*.tiff
site/content/photos/**/*.tif
site/content/photos/**/*.webp

# ============================================================
# OS and editor noise
# ============================================================
.DS_Store
Thumbs.db
