# ============================================================
# Build artifacts — always regenerated, never committed
# ============================================================
node_modules/
dist/
dist-build/
.cache/

# ============================================================
# Large photo binaries (see ADR-011)
#
# Everything under site/ is yours — config, sidecars, posts,
# pages, custom themes. None of it is gitignored except original
# photo files, which are too large for git.
#
# Whether you commit site/ is up to you. It matters if you deploy
# via CI (GitHub Pages, Netlify, etc.) or manage your project as
# a fork/subtree. If you only build locally, you don't need to
# put site/ in git at all.
# ============================================================
site/content/photos/**/*.jpg
site/content/photos/**/*.jpeg
site/content/photos/**/*.png
site/content/photos/**/*.tiff
site/content/photos/**/*.tif
site/content/photos/**/*.webp

# ============================================================
# OS and editor noise
